<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TypingBD Clone - Advanced Practice</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Noto+Sans+Bengali:wght@400;600&family=Poppins:wght@400;600&display=swap');

        :root {
            --bg-color: #f4f6f9;
            --white: #ffffff;
            --primary: #4e73df;
            --success: #1cc88a;
            --danger: #e74a3b;
            --text-dark: #333;
            --text-light: #6c757d;
            --border: #e3e6f0;
        }

        body {
            font-family: 'Poppins', 'Noto Sans Bengali', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-dark);
            margin: 0;
            padding: 20px;
        }

        .container {
            max-width: 1000px;
            margin: 0 auto;
        }

        .card {
            background: var(--white);
            border-radius: 10px;
            padding: 20px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.05);
            margin-bottom: 20px;
        }

        .header {
            text-align: center;
            margin-bottom: 30px;
        }

        /* Dashboard Styles */
        .grid-cards {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 20px;
        }

        .test-card {
            border: 1px solid var(--border);
            border-radius: 10px;
            padding: 20px;
            text-align: center;
            background: #fff;
        }

        .btn {
            padding: 10px 20px;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: 600;
            color: var(--white);
            transition: 0.3s;
            margin: 5px;
        }

        .btn-bangla { background-color: var(--success); }
        .btn-english { background-color: #36b9cc; }
        .btn-finish { background-color: var(--primary); }
        .btn-danger { background-color: var(--danger); }
        .btn-secondary { background-color: var(--text-light); }

        /* Typing Area Styles */
        .timer-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--white);
            padding: 10px 20px;
            border-radius: 5px;
            border: 1px solid var(--border);
            margin-bottom: 15px;
            font-weight: bold;
        }

        .passage-box {
            background: #f8f9fc;
            padding: 20px;
            border-radius: 5px;
            border: 1px solid var(--border);
            font-size: 18px;
            line-height: 1.6;
            margin-bottom: 15px;
            user-select: none;
            max-height: 250px;
            overflow-y: auto;
        }

        textarea {
            width: 100%;
            height: 150px;
            padding: 15px;
            font-size: 18px;
            border: 1px solid var(--border);
            border-radius: 5px;
            box-sizing: border-box;
            resize: none;
            font-family: inherit;
        }

        /* Results Styles */
        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 20px;
        }

        th, td {
            padding: 12px;
            text-align: center;
            border-bottom: 1px solid var(--border);
        }

        th {
            background-color: #f8f9fc;
            color: var(--text-light);
            font-weight: 600;
        }

        .error-text {
            color: var(--danger);
            text-decoration: underline;
        }

        .result-summary {
            display: flex;
            gap: 20px;
            margin-bottom: 20px;
        }

        .summary-box {
            flex: 1;
            padding: 15px;
            border-radius: 5px;
            border: 1px solid var(--border);
            background: #f8f9fc;
        }

        .comparison-box {
            background: #fff;
            padding: 15px;
            border: 1px solid var(--border);
            border-radius: 5px;
            margin-top: 10px;
            line-height: 1.6;
            max-height: 300px;
            overflow-y: auto;
        }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <h2>Advanced Typing Practice Portal</h2>
    </div>

    <!-- 1. Dashboard View -->
    <div id="dashboard-view">
        <div class="grid-cards">
            <div class="test-card">
                <h3>৩ মিনিট টাইপ</h3>
                <p>Trial Mode</p>
                <button class="btn btn-bangla" onclick="startTest('bangla', 3)">Bangla</button>
                <button class="btn btn-english" onclick="startTest('english', 3)">English</button>
            </div>
            <div class="test-card">
                <h3>৫ মিনিট টাইপ</h3>
                <p>Practice Mode</p>
                <button class="btn btn-bangla" onclick="startTest('bangla', 5)">Bangla</button>
                <button class="btn btn-english" onclick="startTest('english', 5)">English</button>
            </div>
            <div class="test-card">
                <h3>১০ মিনিট টাইপ</h3>
                <p>Exam Mode</p>
                <button class="btn btn-bangla" onclick="startTest('bangla', 10)">Bangla</button>
                <button class="btn btn-english" onclick="startTest('english', 10)">English</button>
            </div>
        </div>
        
        <div class="card" style="margin-top: 30px;">
            <h3>My Results</h3>
            <button class="btn btn-danger" onclick="clearHistory()">Delete All Results</button>
            <table>
                <thead>
                    <tr>
                        <th>DATE & TIME</th>
                        <th>LANGUAGE</th>
                        <th>WPM</th>
                        <th>ACCURACY</th>
                        <th>SPEND TIME</th>
                        <th>STATUS</th>
                    </tr>
                </thead>
                <tbody id="history-table-body">
                    <!-- Data will be loaded here via JS -->
                </tbody>
            </table>
        </div>
    </div>

    <!-- 2. Typing Test View -->
    <div id="typing-view" style="display: none;">
        <div class="timer-bar">
            <span id="timer-display">সময়: 00:00 মিনিট</span>
            <button class="btn btn-finish" onclick="finishTest()">Go to Finish</button>
        </div>
        <div class="passage-box" id="original-passage"></div>
        <textarea id="user-input" placeholder="Start writing here..." onpaste="return false;" autocomplete="off"></textarea>
    </div>

    <!-- 3. Result View -->
    <div id="result-view" style="display: none;" class="card">
        <h2 style="text-align:center; color: var(--success);">CHECKING MY RESULT</h2>
        
        <div class="result-summary">
            <div class="summary-box">
                <p><strong>ভাষা:</strong> <span id="res-lang"></span></p>
                <p><strong>সময়কাল:</strong> <span id="res-time"></span></p>
            </div>
            <div class="summary-box">
                <p><strong>প্রতি মিনিটে (WPM):</strong> <span id="res-wpm" style="color:var(--danger); font-weight:bold;"></span></p>
                <p><strong>Accuracy:</strong> <span id="res-acc" style="color:var(--success); font-weight:bold;"></span></p>
                <p><em>৫ Stroke = 1 Word হিসেবে</em></p>
            </div>
            <div class="summary-box">
                <p><strong>মোট টাইপ করা ক্যারেক্টার:</strong> <span id="res-total-char"></span></p>
                <p><strong>সঠিক ক্যারেক্টার:</strong> <span id="res-correct-char"></span></p>
                <p><strong>ভুল শব্দ:</strong> <span id="res-wrong-words"></span></p>
            </div>
        </div>

        <h3>আপনার লেখা ও মূল Passage Comparison:</h3>
        <p><strong>আপনার লেখা (ভুলগুলো লাল চিহ্নিত):</strong></p>
        <div id="comparison-output" class="comparison-box"></div>
        
        <div style="text-align: center; margin-top: 20px;">
            <button class="btn btn-secondary" onclick="goHome()">Back to Home</button>
        </div>
    </div>

</div>

<script>
    // ==========================================
    // PASSAGE DATABASE (Add your 2000+ passages here)
    // ==========================================
    
    const passagesData = {
        english: [
            "Bangladesh, a nation born out of a profound struggle for independence in 1971, has emerged as a remarkable example of resilience and economic growth in South Asia. Despite facing numerous challenges including devastating natural disasters, political shifts, and a massive population density, the country has made significant strides in poverty reduction, health, and education. The garment industry, which is the backbone of the economy, employs millions of workers, primarily women, empowering them and transforming the socio-economic landscape. In recent years, Bangladesh has also been investing heavily in massive infrastructure projects like the Padma Bridge and the Metro Rail in Dhaka, signaling a strong commitment to modernization and regional connectivity. As the world deals with unprecedented economic shifts, Bangladesh continues to adapt, aiming to graduate from the Least Developed Countries status and moving towards becoming a middle-income nation by the end of the decade.",
            
            "The rapid advancement of Artificial Intelligence (AI) and Machine Learning technologies has fundamentally reshaped the global landscape, influencing everything from healthcare and education to finance and national security. In recent years, generative AI models have demonstrated an uncanny ability to process natural language, create art, and write complex code, sparking intense debates about the future of human labor and creativity. While optimists argue that AI will augment human capabilities, automate mundane tasks, and solve complex global challenges such as climate change modeling and disease prediction, critics warn of severe ethical implications. Issues concerning algorithmic bias, data privacy, and the potential for autonomous weapons systems require immediate international regulatory frameworks. As AI systems become more integrated into critical infrastructure, ensuring robust cybersecurity measures and maintaining human oversight will be paramount.",
            
            "Climate change remains the most pressing existential threat facing humanity in the 21st century. The continuous emission of greenhouse gases, primarily from the burning of fossil fuels and massive deforestation, has led to a steady rise in global temperatures, resulting in extreme weather events worldwide. Nations around the globe are witnessing unprecedented heatwaves, devastating floods, and prolonged droughts that disrupt agricultural supply chains and displace vulnerable communities. The historic Paris Agreement aimed to unite the international community in limiting global warming to well below 2 degrees Celsius compared to pre-industrial levels, yet recent data suggests that current commitments fall dangerously short. Transitioning to renewable energy sources such as solar, wind, and geothermal power is no longer just an environmental imperative but an economic necessity."
        ],
        bangla: [
            "বাংলাদেশের মুক্তিযুদ্ধ শুধু একটি সশস্ত্র সংগ্রাম ছিল না, এটি ছিল একটি জাতির দীর্ঘদিনের শোষণ ও বঞ্চনার বিরুদ্ধে রুখে দাঁড়ানোর চূড়ান্ত বহিঃপ্রকাশ। ১৯৭১ সালের ২৬শে মার্চ স্বাধীনতা ঘোষণার পর থেকে দীর্ঘ নয় মাস রক্তক্ষয়ী যুদ্ধের মাধ্যমে এদেশের মুক্তিকামী মানুষ পাকিস্তানি হানাদার বাহিনীর বিরুদ্ধে জয়লাভ করে। ত্রিশ লাখ শহীদের আত্মত্যাগ এবং দুই লাখ মা-বোনের সম্ভ্রমের বিনিময়ে অর্জিত এই স্বাধীনতা আমাদের অহংকার। স্বাধীনতা পরবর্তী সময়ে যুদ্ধবিধ্বস্ত একটি দেশ থেকে আজকের উদীয়মান অর্থনীতির দেশ হিসেবে বাংলাদেশের উত্থান সত্যি বিস্ময়কর। কৃষি, শিল্প, পোশাক খাত এবং প্রবাসী আয়ের ওপর ভর করে বাংলাদেশ আজ বিশ্বের দরবারে উন্নয়নের এক রোল মডেল হিসেবে পরিচিতি পেয়েছে। পদ্মা সেতু, মেট্রোরেল, কর্ণফুলী টানেল এবং রূপপুর পারমাণবিক বিদ্যুৎকেন্দ্রের মতো মেগা প্রকল্পগুলো দেশের যোগাযোগ ও অবকাঠামো খাতে এক যুগান্তকারী পরিবর্তন এনেছে।",
            
            "বর্তমান বিশ্বে তথ্যপ্রযুক্তি এবং কৃত্রিম বুদ্ধিমত্তা বা আর্টিফিশিয়াল ইন্টেলিজেন্স (এআই) এক অভাবনীয় বিপ্লব ঘটিয়েছে। মানুষের দৈনন্দিন জীবনের প্রায় প্রতিটি ক্ষেত্রে এখন প্রযুক্তির ছোঁয়া লেগেছে। চিকিৎসা বিজ্ঞান থেকে শুরু করে মহাকাশ গবেষণা, যোগাযোগ ব্যবস্থা, ব্যাংকিং খাত এমনকি শিক্ষাক্ষেত্রেও এআই-এর ব্যবহার দিন দিন বৃদ্ধি পাচ্ছে। তবে প্রযুক্তির এই অবাধ ব্যবহারের কিছু নেতিবাচক দিকও রয়েছে। সাইবার নিরাপত্তা, ব্যক্তিগত তথ্যের গোপনীয়তা এবং সাইবার ক্রাইম বর্তমান সময়ের অন্যতম বড় চ্যালেঞ্জ। বিশেষ করে ডিপফেক প্রযুক্তি এবং ফেক নিউজের ছড়াছড়ি সমাজ ব্যবস্থায় গভীর প্রভাব ফেলছে। তাই প্রযুক্তির সঠিক ও নিরাপদ ব্যবহার নিশ্চিত করতে আন্তর্জাতিক পর্যায়ে কঠোর সাইবার আইন ও নীতিমালা প্রণয়নের দাবি জোরালো হচ্ছে। আগামীর বিশ্ব হবে পুরোপুরি ডেটা নির্ভর, তাই এই প্রতিযোগিতায় টিকে থাকতে হলে প্রযুক্তিগত শিক্ষার কোনো বিকল্প নেই।",
            
            "বিশ্ব উষ্ণায়ন বা গ্লোবাল ওয়ার্মিং বর্তমান শতাব্দীর অন্যতম প্রধান বৈশ্বিক সংকট। কার্বন ডাই-অক্সাইড, মিথেনসহ অন্যান্য গ্রিনহাউস গ্যাসের মাত্রাতিরিক্ত নিঃসরণের ফলে পৃথিবীর তাপমাত্রা ক্রমাগত বৃদ্ধি পাচ্ছে। এর ফলে মেরু অঞ্চলের বরফ গলে সমুদ্রপৃষ্ঠের উচ্চতা বৃদ্ধি পাচ্ছে, যা বাংলাদেশ, মালদ্বীপসহ বিশ্বের অনেক উপকূলীয় দেশের জন্য এক অশনি সংকেত। জলবায়ু পরিবর্তনের কারণে বন্যা, খরা, ঘূর্ণিঝড় ও জলোচ্ছ্বাসের মতো প্রাকৃতিক দুর্যোগের মাত্রা ও তীব্রতা বহুগুণ বৃদ্ধি পেয়েছে। কৃষিকাজের ওপর এর বিরূপ প্রভাব পড়ছে, ফলে বিশ্বব্যাপী খাদ্য নিরাপত্তার ঝুঁকি তৈরি হচ্ছে। পরিবেশের এই চরম বিপর্যয় রোধ করতে হলে জীবাশ্ম জ্বালানির ব্যবহার কমিয়ে নবায়নযোগ্য জ্বালানি যেমন- সৌরশক্তি ও বায়ুশক্তির ব্যবহার বাড়াতে হবে। একইসাথে প্রচুর পরিমাণে বৃক্ষরোপণ এবং পরিবেশ রক্ষায় আন্তর্জাতিক চুক্তিগুলোর যথাযথ বাস্তবায়ন অত্যন্ত জরুরি।"
        ]
    };

    // Keep track of used passages to avoid repetition
    let usedPassages = {
        english: [],
        bangla: []
    };

    // Function to get a random, non-repeating passage
    function getRandomPassage(lang) {
        const pool = passagesData[lang];
        let used = usedPassages[lang];

        // If all passages are used, reset the tracker
        if (used.length >= pool.length) {
            usedPassages[lang] = [];
            used = usedPassages[lang];
        }

        // Find available indices
        let availableIndices = pool.map((_, index) => index).filter(index => !used.includes(index));
        
        // Pick a random index
        let randomIndex = availableIndices[Math.floor(Math.random() * availableIndices.length)];
        
        // Mark as used
        used.push(randomIndex);

        return pool[randomIndex];
    }

    // ==========================================
    // CORE LOGIC
    // ==========================================

    let currentLang = '';
    let totalTime = 0; // in seconds
    let timeLeft = 0;
    let timerInterval = null;
    let isTestRunning = false;
    let originalText = "";

    const dashboardView = document.getElementById('dashboard-view');
    const typingView = document.getElementById('typing-view');
    const resultView = document.getElementById('result-view');
    const passageBox = document.getElementById('original-passage');
    const userInput = document.getElementById('user-input');
    const timerDisplay = document.getElementById('timer-display');

    window.onload = loadHistory;

    function startTest(lang, minutes) {
        currentLang = lang;
        totalTime = minutes * 60;
        timeLeft = totalTime;
        
        // Fetch a random passage dynamically
        originalText = getRandomPassage(lang);

        // UI Setup
        dashboardView.style.display = 'none';
        resultView.style.display = 'none';
        typingView.style.display = 'block';
        
        passageBox.innerText = originalText;
        userInput.value = '';
        userInput.disabled = false;
        userInput.focus();
        
        updateTimerDisplay();
        
        isTestRunning = true;
        clearInterval(timerInterval);
        timerInterval = setInterval(() => {
            timeLeft--;
            updateTimerDisplay();
            if (timeLeft <= 0) {
                finishTest();
            }
        }, 1000);
    }

    function updateTimerDisplay() {
        let m = Math.floor(timeLeft / 60);
        let s = timeLeft % 60;
        timerDisplay.innerText = `সময়: ${m < 10 ? '0'+m : m}:${s < 10 ? '0'+s : s} মিনিট`;
    }

    function finishTest() {
        if (!isTestRunning) return;
        isTestRunning = false;
        clearInterval(timerInterval);
        userInput.disabled = true;

        calculateAndShowResult();
    }

    function calculateAndShowResult() {
        const typedText = userInput.value.trim();
        const timeSpentSec = totalTime - Math.max(0, timeLeft);
        const timeSpentMin = timeSpentSec / 60;

        const origWords = originalText.split(/\s+/);
        const typedWords = typedText.split(/\s+/);
        
        let correctChars = 0;
        let wrongWordsCount = 0;
        let highlightedHTML = "";

        for (let i = 0; i < typedWords.length; i++) {
            if (typedWords[i] === "") continue;

            if (origWords[i] && typedWords[i] === origWords[i]) {
                correctChars += typedWords[i].length + 1; 
                highlightedHTML += typedWords[i] + " ";
            } else {
                wrongWordsCount++;
                highlightedHTML += `<span class="error-text">${typedWords[i]}</span> `;
            }
        }

        const totalTypedChars = typedText.length;
        let wpm = 0;
        if (timeSpentMin > 0) {
            wpm = Math.round((correctChars / 5) / timeSpentMin);
        }
        
        let accuracy = 0;
        if (totalTypedChars > 0) {
            accuracy = Math.round((correctChars / totalTypedChars) * 100);
            if(accuracy > 100) accuracy = 100;
        }

        document.getElementById('res-lang').innerText = currentLang.toUpperCase();
        
        let m = Math.floor(timeSpentSec / 60);
        let s = timeSpentSec % 60;
        document.getElementById('res-time').innerText = `${m} Min ${s} Sec`;
        
        document.getElementById('res-wpm').innerText = wpm;
        document.getElementById('res-acc').innerText = accuracy + '%';
        document.getElementById('res-total-char').innerText = totalTypedChars;
        document.getElementById('res-correct-char').innerText = correctChars;
        document.getElementById('res-wrong-words').innerText = wrongWordsCount;
        document.getElementById('comparison-output').innerHTML = highlightedHTML || "<em>কোনো টেক্সট ইনপুট দেওয়া হয়নি।</em>";

        saveResult({
            date: new Date().toLocaleString(),
            lang: currentLang,
            wpm: wpm,
            accuracy: accuracy,
            timeSpent: `${m}m ${s}s`,
            status: accuracy >= 80 ? 'PASS' : 'FAIL'
        });

        typingView.style.display = 'none';
        resultView.style.display = 'block';
    }

    function saveResult(resultObj) {
        let history = JSON.parse(localStorage.getItem('typingHistory')) || [];
        history.unshift(resultObj); 
        localStorage.setItem('typingHistory', JSON.stringify(history));
    }

    function loadHistory() {
        let history = JSON.parse(localStorage.getItem('typingHistory')) || [];
        const tbody = document.getElementById('history-table-body');
        tbody.innerHTML = '';

        if(history.length === 0) {
            tbody.innerHTML = '<tr><td colspan="6">No results found</td></tr>';
            return;
        }

        history.forEach(item => {
            let statusColor = item.status === 'PASS' ? 'var(--success)' : 'var(--danger)';
            let tr = document.createElement('tr');
            tr.innerHTML = `
                <td>${item.date}</td>
                <td style="text-transform: capitalize;">${item.lang}</td>
                <td>${item.wpm}</td>
                <td>${item.accuracy}%</td>
                <td>${item.timeSpent}</td>
                <td style="color: ${statusColor}; font-weight: bold;">${item.status}</td>
            `;
            tbody.appendChild(tr);
        });
    }

    function clearHistory() {
        if(confirm("Are you sure you want to delete all results?")) {
            localStorage.removeItem('typingHistory');
            loadHistory();
        }
    }

    function goHome() {
        resultView.style.display = 'none';
        dashboardView.style.display = 'block';
        loadHistory();
    }
</script>

</body>
</html>
